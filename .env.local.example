# Copy this file to .env.local and fill in the values to run locally.
# In production, set the same variables in Vercel:
#   Project → Settings → Environment Variables (Production, Preview, Development).
#
# .env.local is gitignored — never commit a real .env.local with secrets.

# -----------------------------------------------------------------------------
# Resend — transactional email provider
# -----------------------------------------------------------------------------
# Sign up at https://resend.com, verify the gsf.com.do domain (DNS records),
# then create an API key at https://resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Supabase — database for storing complaint submissions
# -----------------------------------------------------------------------------
# Create a project at https://supabase.com. Both values live in:
#   Settings → API
# Use the `service_role` key (secret, NOT the `anon` key). It bypasses RLS.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Email address that receives complaint notifications
# -----------------------------------------------------------------------------
# This mailbox should be monitored by the compliance / contact team.
COMPLAINTS_NOTIFICATION_EMAIL=contacto@gsf.com.do

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — captcha on the /complaints form
# -----------------------------------------------------------------------------
# Create a widget at https://dash.cloudflare.com → Turnstile → Add site.
# The values below are Cloudflare's PUBLIC dev test keys: the site key always
# passes and the secret key always verifies OK. Use them locally so you do not
# need to register localhost in your real widget. Replace with real values in
# Vercel (Production + Preview environments).
#
# Dev test keys reference: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting on the /api/complaints route
# -----------------------------------------------------------------------------
# Create a Regional Redis DB at https://console.upstash.com (Free tier).
# Both values come from the database's "REST API" section.
# If these are unset, the route logs a warning and falls back to allowing all
# traffic — useful for local dev without an Upstash account.
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# (Optional) Production site URL — used by SEO files (sitemap, robots, JSON-LD).
# Defaults to the current Vercel staging URL if not set.
# Set this when GSF promotes to its production domain (e.g. gsf.com.do).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://gsf.com.do
