# Copy this file to .env.local and fill in the values to run locally.
# In production, set the same variables in Vercel:
#   Project → Settings → Environment Variables (Production, Preview, Development).
#
# .env.local is gitignored — never commit a real .env.local with secrets.

# -----------------------------------------------------------------------------
# Resend — transactional email provider
# -----------------------------------------------------------------------------
# Sign up at https://resend.com, verify the gsf.com.do domain (DNS records),
# then create an API key at https://resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Supabase — database for storing complaint submissions
# -----------------------------------------------------------------------------
# Create a project at https://supabase.com. Both values live in:
#   Settings → API
# Use the `service_role` key (secret, NOT the `anon` key). It bypasses RLS.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Email address that receives complaint notifications
# -----------------------------------------------------------------------------
# This mailbox should be monitored by the compliance / contact team.
COMPLAINTS_NOTIFICATION_EMAIL=contacto@gsf.com.do

# -----------------------------------------------------------------------------
# (Optional) Production site URL — used by SEO files (sitemap, robots, JSON-LD).
# Defaults to the current Vercel staging URL if not set.
# Set this when GSF promotes to its production domain (e.g. gsf.com.do).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://gsf.com.do
